{
  "name": "abcjs",
  "version": "6.6.4",
  "description": "Renderer for abc music notation",
  "main": "index.js",
  "types": "types/index.d.ts",
  "scripts": {
    "build": "rm dist/* && npm run build:basic && npm run build:plugin && npm run build:basic-min",
    "build:basic": "vite build --mode development:basic",
    "build:basic-min": "vite build --mode production:basic",
    "build:plugin": "vite build --mode production:plugin",
    "test-server": "npx http-server",
    "test": "concurrently \"http-server\" \"npx opener http://localhost:8080/tests/all.html\"",
    "docs:dev": "vuepress dev docs",
    "docs:build": "vuepress build docs",
    "build:analyze": "npm run build:basic -- --env analyze",
    "lint": "eslint ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/paulrosen/abcjs.git"
  },
  "keywords": [
    "abc",
    "music",
    "notation",
    "midi",
    "webaudio"
  ],
  "author": "Paul Rosen <paul@paulrosen.net> (https://abcjs.net)",
  "contributors": [
    "Gregory Dyke",
    "Jean-Yves Mengant",
    "Todd Brown",
    "Thomas Chandelle"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/paulrosen/abcjs/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/paulrosen"
  },
  "homepage": "https://abcjs.net",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@tarp/require": "1.4.3",
    "chai": "4.3.7",
    "concurrently": "7.6.0",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "http-server": "14.1.1",
    "jiti": "^2.7.0",
    "mocha": "10.2.0",
    "opener": "1.5.2",
    "typescript-eslint": "^8.63.0",
    "vite": "^4.0.5",
    "vite-plugin-banner": "^0.8.1",
    "vuepress": "2.0.0-beta.60",
    "vuex": "4.1.0"
  }
}
